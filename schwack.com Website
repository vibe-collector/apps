<!-- HERO -->

<section class="hero">
  <div>
    <div class="hero-eyebrow">Unternehmensberatung · Wien</div>
    <h1 class="hero-title">
      Klarheit ist<br>
      die eigentliche<br>
      <em>Arbeit.</em>
    </h1>
    <p class="hero-sub">
      Bevor Strategien greifen, Veränderungen gelingen oder KI liefert —
      muss klar sein, was eigentlich gewollt wird.
    </p>
    <a href="#insight" class="hero-cta">Mehr erfahren →</a>
