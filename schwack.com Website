<style>
:root{
  --bg:#141414;--bg-mid:#1d1d1d;--bg-card:#222222;
  --text:#f0ede8;--muted:#7a7870;
  --teal:#00b09a;--teal-dk:#007d75;--line:#2e2e2e;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-weight:300;line-height:1.7;overflow-x:hidden}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1rem 4rem;background:rgba(19,19,19,.95);backdrop-filter:blur(10px);border-bottom:1px solid var(–line)}
.nav-brand{display:flex;align-items:center;gap:.9rem;text-decoration:none}
.nav-name{font-size:.82rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(–text);line-height:1.25}
.nav-name span{display:block;font-size:.63rem;color:var(–muted);letter-spacing:.12em;font-weight:300}
.nav-link{font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);text-decoration:none;border:1px solid var(–line);padding:.45rem 1rem;border-radius:2px;transition:color .2s,border-color .2s}
.nav-link:hover{color:var(–teal);border-color:var(–teal)}

.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:8rem 4rem 5rem;gap:4rem;position:relative;overflow:hidden}
.hero::before{content:’’;position:absolute;inset:0;background:radial-gradient(ellipse 55% 50% at 80% 38%,rgba(0,176,154,.08) 0%,transparent 65%),radial-gradient(ellipse 30% 40% at 18% 72%,rgba(0,107,96,.05) 0%,transparent 60%);pointer-events:none}
.hero-eyebrow{font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(–teal);margin-bottom:1.8rem;display:flex;align-items:center;gap:.8rem}
.hero-eyebrow::before{content:’’;display:block;width:2rem;height:1px;background:var(–teal)}
.hero-title{font-family:‘Cormorant Garamond’,serif;font-size:clamp(3rem,5.5vw,4.6rem);font-weight:300;line-height:1.12;margin-bottom:2rem}
.hero-title em{font-style:italic;color:var(–teal)}
.hero-sub{font-size:1rem;color:var(–muted);line-height:1.82;max-width:40ch;margin-bottom:2.5rem}
.hero-cta{display:inline-flex;align-items:center;gap:.5rem;font-size:.78rem;letter-spacing:.14em;text-transform:uppercase;color:var(–teal);text-decoration:none;border-bottom:1px solid rgba(0,176,154,.3);padding-bottom:.2rem;transition:border-color .2s}
.hero-cta:hover{border-color:var(–teal)}
.hero-right{display:flex;flex-direction:column;gap:2rem;padding-left:3rem;border-left:1px solid var(–line)}
.hero-quote{font-family:‘Cormorant Garamond’,serif;font-size:1.55rem;font-weight:300;font-style:italic;line-height:1.55;color:rgba(240,237,232,.72)}
.hero-quote-attr{font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(–muted)}

.section-divider{height:1px;background:var(–line);margin:0 4rem}
.section-label{font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:var(–muted);padding-top:.4rem;position:sticky;top:5rem;display:flex;align-items:center;gap:.6rem}
.section-label::before{content:’’;display:block;width:1.2rem;height:1px;background:var(–teal);flex-shrink:0}
.two-col{display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start}

.insight{padding:7rem 4rem}
.insight-content h2{font-family:‘Cormorant Garamond’,serif;font-size:clamp(2rem,3.5vw,2.8rem);font-weight:300;line-height:1.3;margin-bottom:2rem}
.insight-content h2 strong{font-weight:600;color:var(–teal)}
.insight-content p{color:rgba(240,237,232,.65);font-size:.97rem;line-height:1.85;max-width:62ch;margin-bottom:1.4rem}
.insight-cards{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(–line);margin-top:3rem;border:1px solid var(–line)}
.insight-card{background:var(–bg-card);padding:2rem;transition:background .25s}
.insight-card:hover{background:#272727}
.insight-card-num{font-family:‘Cormorant Garamond’,serif;font-size:2rem;font-weight:300;color:var(–teal);opacity:.4;line-height:1;margin-bottom:.8rem}
.insight-card h3{font-size:.85rem;font-weight:500;color:var(–text);margin-bottom:.5rem}
.insight-card p{font-size:.84rem;color:var(–muted);line-height:1.7}

.thema{padding:7rem 4rem}
.thema-content h2{font-family:‘Cormorant Garamond’,serif;font-size:clamp(2rem,3.5vw,2.8rem);font-weight:300;line-height:1.3;margin-bottom:2rem}
.thema-content p{color:rgba(240,237,232,.65);font-size:.97rem;line-height:1.85;max-width:62ch;margin-bottom:1.4rem}
.thema-quote{margin-top:2.5rem;padding:1.8rem 2rem;border-left:2px solid var(–teal);background:var(–bg-card)}
.thema-quote p{font-family:‘Cormorant Garamond’,serif;font-size:1.35rem;font-style:italic;font-weight:300;color:rgba(240,237,232,.82);line-height:1.55;margin:0}
.thema-example{margin-top:2.5rem;border-left:2px solid var(–teal);padding-left:1.8rem}
.thema-example-label{font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(–teal);margin-bottom:1rem}
.thema-steps{display:flex;flex-direction:column;gap:.65rem}
.thema-step{display:flex;align-items:baseline;gap:1rem;font-size:.9rem;color:rgba(240,237,232,.65)}
.thema-step-num{font-family:‘Cormorant Garamond’,serif;font-size:.85rem;color:var(–teal);min-width:1.2rem}
.thema-step.ai{color:var(–muted);font-style:italic;margin-top:.6rem;padding-top:.8rem;border-top:1px solid var(–line)}

.leistungen{padding:7rem 4rem}
.leistung-item{padding:2rem 0;border-bottom:1px solid var(–line);display:grid;grid-template-columns:3fr 1.5fr;gap:2rem;align-items:start;cursor:default}
.leistung-item:first-child{border-top:1px solid var(–line)}
.leistung-title{font-family:‘Cormorant Garamond’,serif;font-size:1.45rem;font-weight:400;color:var(–text);margin-bottom:.5rem;transition:color .2s}
.leistung-item:hover .leistung-title{color:var(–teal)}
.leistung-desc{font-size:.87rem;color:var(–muted);line-height:1.75}
.leistung-tag{font-size:.67rem;letter-spacing:.12em;text-transform:uppercase;color:var(–muted);text-align:right;padding-top:.4rem;opacity:.5}

.ueber{padding:7rem 4rem}
.ueber-content p{color:rgba(240,237,232,.65);line-height:1.85;max-width:60ch;margin-bottom:1.2rem;font-size:.97rem}
.ueber-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:2rem}
.ueber-tag{font-size:.69rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid var(–line);color:var(–muted);padding:.35rem .9rem;border-radius:2px;transition:border-color .2s,color .2s}
.ueber-tag:hover{border-color:var(–teal);color:var(–teal)}

.kontakt{padding:7rem 4rem;position:relative}
.kontakt::before{content:’’;position:absolute;top:0;left:4rem;right:4rem;height:2px;background:linear-gradient(to right,var(–teal),transparent)}
.kontakt-intro h2{font-family:‘Cormorant Garamond’,serif;font-size:clamp(2rem,3.5vw,2.8rem);font-weight:300;line-height:1.3;margin-bottom:1rem}
.kontakt-intro p{color:rgba(240,237,232,.6);line-height:1.85;max-width:55ch;font-size:.97rem;margin-bottom:3rem}

footer{padding:1.8rem 4rem;border-top:1px solid var(–line);display:flex;justify-content:space-between;align-items:center;gap:1rem}
.footer-left{display:flex;align-items:center;gap:.8rem}
footer span{font-size:.7rem;color:var(–muted);letter-spacing:.04em}
footer a{font-size:.7rem;color:var(–muted);text-decoration:none;transition:color .2s;letter-spacing:.06em}
footer a:hover{color:var(–teal)}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.hero-eyebrow{animation:fadeUp .6s ease .1s both}
.hero-title  {animation:fadeUp .6s ease .25s both}
.hero-sub    {animation:fadeUp .6s ease .38s both}
.hero-cta    {animation:fadeUp .6s ease .5s both}
.hero-right  {animation:fadeUp .6s ease .4s both}

@media(max-width:900px){
nav{padding:1rem 1.6rem}
.hero{padding:6rem 1.6rem 4rem;grid-template-columns:1fr;gap:2.5rem}
.two-col{grid-template-columns:1fr;gap:2rem}
.insight,.thema,.leistungen,.ueber,.kontakt{padding:5rem 1.6rem}
.hero-right{padding-left:0;border-left:none;border-top:1px solid var(–line);padding-top:2rem}
.insight-cards,.logo-cards{grid-template-columns:1fr}
.section-label{position:static}
.section-divider{margin:0 1.6rem}
.leistung-item{grid-template-columns:1fr}
.leistung-tag{text-align:left}
footer{flex-direction:column;text-align:center;padding:1.6rem}
.thema.mid::before,.kontakt::before{left:1.6rem;right:1.6rem}
}
</style>

</head>
