<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Impostor</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;700&display=swap');

  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --card: #1a1a24;
    --border: #2a2a3a;
    --accent: #e8ff00;
    --accent2: #ff3c6e;
    --text: #f0f0f5;
    --muted: #6b6b80;
    --impostor: #ff3c6e;
    --safe: #00e5a0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, #1e1e3a 0%, transparent 70%);
    pointer-events: none;
  }

  .app {
    width: 100%;
    max-width: 480px;
    min-height: 100svh;
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .screen {
    display: none;
    flex-direction: column;
    flex: 1;
    animation: fadeUp 0.35s ease;
  }
  .screen.active { display: flex; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* TYPOGRAPHY */
  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    letter-spacing: 4px;
    line-height: 1;
    color: var(--accent);
    text-shadow: 0 0 40px rgba(232,255,0,0.3);
  }
  .logo span { color: var(--accent2); }

  h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
    color: var(--accent);
  }

  .subtitle {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  /* INPUTS */
  .input-row {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  input[type="text"], textarea {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    padding: 14px 18px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  input[type="text"]:focus, textarea:focus { border-color: var(--accent); }
  input[type="text"]::placeholder, textarea::placeholder { color: var(--muted); }

  textarea {
    resize: vertical;
    min-height: 120px;
    font-size: 14px;
    line-height: 1.6;
  }

  /* BUTTONS */
  .btn {
    border: none;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
    padding: 14px 22px;
    font-size: 15px;
  }
  .btn:active { transform: scale(0.96); }

  .btn-accent {
    background: var(--accent);
    color: #000;
    font-size: 17px;
    padding: 16px;
    border-radius: 14px;
    letter-spacing: 0.5px;
  }

  .btn-ghost {
    background: var(--card);
    border: 1.5px solid var(--border);
    color: var(--text);
  }

  .btn-icon {
    background: var(--accent);
    color: #000;
    font-size: 20px;
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .btn-danger {
    background: transparent;
    border: 1.5px solid var(--accent2);
    color: var(--accent2);
  }

  .btn-sm {
    padding: 8px 14px;
    font-size: 13px;
    border-radius: 8px;
  }

  /* PLAYER LIST */
  .player-list {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow-y: auto;
    max-height: 240px;
  }

  .player-chip {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 12px 16px;
    animation: fadeUp 0.25s ease;
  }

  .player-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  .player-name { font-weight: 500; flex: 1; }

  .remove-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 20px;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.2s;
  }
  .remove-btn:hover { color: var(--accent2); }

  /* REVEAL SCREEN */
  .reveal-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 20px;
    padding: 32px 28px;
    text-align: center;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    position: relative;
    overflow: hidden;
  }

  .reveal-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .reveal-card.impostor-card::before {
    background: radial-gradient(ellipse at center, rgba(255,60,110,0.12) 0%, transparent 70%);
    opacity: 1;
  }

  .reveal-card.safe-card::before {
    background: radial-gradient(ellipse at center, rgba(0,229,160,0.1) 0%, transparent 70%);
    opacity: 1;
  }

  .player-name-big {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 44px;
    letter-spacing: 3px;
    line-height: 1;
  }

  .hidden-word {
    background: var(--border);
    border-radius: 50px;
    padding: 14px 24px;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 1px;
    width: 100%;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s;
    user-select: none;
    border: 1.5px solid var(--border);
  }

  .word-display {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    letter-spacing: 4px;
    line-height: 1;
    padding: 8px 0;
  }

  .word-display.impostor-word { color: var(--impostor); }
  .word-display.safe-word { color: var(--safe); }

  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .badge-impostor { background: rgba(255,60,110,0.15); color: var(--impostor); border: 1px solid rgba(255,60,110,0.3); }
  .badge-safe { background: rgba(0,229,160,0.12); color: var(--safe); border: 1px solid rgba(0,229,160,0.25); }

  .hint-text {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    max-width: 280px;
  }

  /* PROGRESS */
  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 24px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .player-counter {
    font-size: 13px;
    color: var(--muted);
    text-align: center;
    margin-bottom: 16px;
  }

  /* SECTION BOXES */
  .section-box {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 16px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
  }

  .section-header-title {
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chevron {
    color: var(--muted);
    font-size: 12px;
    transition: transform 0.2s;
  }
  .chevron.open { transform: rotate(180deg); }

  .collapsible-body {
    display: none;
    margin-top: 14px;
  }
  .collapsible-body.open { display: block; }

  .pair-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    max-height: 220px;
    overflow-y: auto;
  }

  .pair-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .pair-item:hover, .pair-item.selected { border-color: var(--accent); }
  .pair-item .pair-main { font-weight: 700; color: var(--safe); font-size: 13px; }
  .pair-item .pair-impostor { color: var(--impostor); }
  .pair-item .pair-label { color: var(--muted); font-size: 10px; letter-spacing: 0.5px; text-transform: uppercase; }

  .pair-random-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 12px;
    cursor: pointer;
    transition: border-color 0.2s;
    grid-column: span 2;
    text-align: center;
  }
  .pair-random-item:hover, .pair-random-item.selected { border-color: var(--accent); }
  .pair-random-item .pair-main { font-weight: 700; color: var(--accent); font-size: 13px; }

  /* BOTTOM AREA */
  .bottom-actions {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* START SCREEN */
  .hero-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
    padding: 20px 0;
  }

  .tagline {
    font-size: 16px;
    color: var(--muted);
    max-width: 300px;
    line-height: 1.6;
  }

  .rules-box {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 18px;
    margin-top: 12px;
  }

  .rule-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 8px 0;
    font-size: 14px;
    line-height: 1.5;
  }
  .rule-item:not(:last-child) { border-bottom: 1px solid var(--border); }
  .rule-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent);
    color: #000;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ROUND DONE */
  .round-done-card {
    background: var(--card);
    border: 1.5px solid var(--accent);
    border-radius: 20px;
    padding: 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    flex: 1;
    justify-content: center;
  }

  .big-emoji { font-size: 64px; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 12px 22px;
    font-size: 14px;
    font-weight: 500;
    transition: transform 0.3s;
    z-index: 100;
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,60,110,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(255,60,110,0); }
  }
  .impostor-card { animation: pulse 2s infinite; }

  .dots { display: flex; gap: 8px; justify-content: center; margin-top: 8px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); transition: background 0.2s; }
  .dot.done { background: var(--accent); }
  .dot.current { background: var(--accent2); }

  /* ── GROUP TOGGLES ── */
  .group-toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 4px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    gap: 12px;
  }
  .group-toggle-row:last-child { border-bottom: none; }
  .group-toggle-label { flex: 1; }
  .group-count { color: var(--muted); font-size: 12px; margin-right: 8px; }

  .toggle-switch {
    width: 44px;
    height: 24px;
    border-radius: 12px;
    background: var(--border);
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
    border: none;
  }
  .toggle-switch.on { background: var(--accent); }
  .toggle-switch::after {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    top: 3px;
    left: 3px;
    transition: left 0.2s;
  }
  .toggle-switch.on::after { left: 23px; }

  .group-select-all {
    font-size: 12px;
    color: var(--accent);
    text-decoration: underline;
    cursor: pointer;
    padding: 8px 0 4px;
    display: block;
    text-align: right;
  }

  /* ═══════════════ WORD MANAGER ═══════════════ */
  .wm-tabs {
    display: flex;
    gap: 8px;
    margin: 16px 0;
    flex-shrink: 0;
  }

  .wm-tab {
    flex: 1;
    padding: 10px 6px;
    text-align: center;
    border-radius: 10px;
    background: var(--card);
    border: 1.5px solid var(--border);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    color: var(--muted);
  }
  .wm-tab.active { border-color: var(--accent); color: var(--accent); }

  .wm-panel { display: none; flex-direction: column; gap: 14px; }
  .wm-panel.active { display: flex; }

  .custom-pair-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .custom-pair-item {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    animation: fadeUp 0.2s ease;
  }

  .custom-pair-words {
    flex: 1;
    display: flex;
    gap: 6px;
    align-items: center;
    font-size: 14px;
    flex-wrap: wrap;
  }

  .cw-main { color: var(--safe); font-weight: 700; }
  .cw-sep { color: var(--muted); font-size: 12px; }
  .cw-impostor { color: var(--impostor); }
  .cw-source {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 20px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .cw-source.builtin { background: rgba(107,107,128,0.2); color: var(--muted); }
  .cw-source.custom { background: rgba(232,255,0,0.12); color: var(--accent); }

  .import-format-box {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.8;
    font-family: monospace;
  }

  .filter-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn.active { border-color: var(--accent); color: var(--accent); }

  .stats-row {
    display: flex;
    gap: 10px;
    flex-shrink: 0;
  }

  .stat-chip {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    text-align: center;
  }
  .stat-chip strong { font-size: 22px; font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px; }
  .stat-chip span { color: var(--muted); }

  .drop-zone {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
    position: relative;
    line-height: 1.6;
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--accent);
    background: rgba(232,255,0,0.04);
    color: var(--text);
  }
  .drop-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .nav-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .nav-back {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s;
  }
  .nav-back:hover { border-color: var(--accent); }

  .scrollable {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 20px;
  }

  .input-label {
    font-size: 12px;
    color: var(--muted);
    display: block;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .field-group { display: flex; flex-direction: column; gap: 6px; }

  hr.sep { height: 1px; background: var(--border); border: none; }

  /* ── EDIT MODAL ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    z-index: 200;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }
  .modal-sheet {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 24px 24px 0 0;
    padding: 28px 24px 40px;
    width: 100%;
    max-width: 480px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.34,1.1,0.64,1);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .modal-backdrop.open .modal-sheet {
    transform: translateY(0);
  }
  .modal-handle {
    width: 40px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin: 0 auto 8px;
  }
  .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
    color: var(--accent);
  }
  .modal-actions {
    display: flex;
    gap: 10px;
    margin-top: 4px;
  }
  .modal-actions .btn { flex: 1; }

  .cw-imp-chip {
    background: rgba(255,60,110,0.15);
    color: var(--accent2);
    border-radius: 6px;
    padding: 1px 7px;
    font-size: 12px;
  }

  /* Edit pencil button on pair items */
  .edit-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 16px;
    cursor: pointer;
    padding: 4px 6px;
    line-height: 1;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .edit-btn:hover { color: var(--accent); }
</style>
</head>
<body>
<div class="app">

  <!-- ══════════════ SCREEN: START ══════════════ -->
  <div class="screen active" id="screen-start">
    <div class="hero-area">
      <div class="logo">IMPOS<span>T</span>OR</div>
      <p class="tagline">Wer lügt? Wer weiß es wirklich? Finde den Eindringling in eurer Mitte.</p>
      <div class="rules-box">
        <div class="rule-item"><span class="rule-num">1</span><span>Alle Spieler geben ihren Namen ein</span></div>
        <div class="rule-item"><span class="rule-num">2</span><span>Jeder schaut reihum heimlich auf sein Wort</span></div>
        <div class="rule-item"><span class="rule-num">3</span><span>Alle diskutieren – der Impostor versucht, sich zu verstecken</span></div>
        <div class="rule-item"><span class="rule-num">4</span><span>Abgestimmt wird: Wer ist der Eindringling?</span></div>
      </div>
    </div>
    <div class="bottom-actions">
      <button class="btn btn-accent" onclick="goto('screen-players')">Los geht's →</button>
      <button class="btn btn-ghost" onclick="showPinPrompt()">📝 Wortpaare verwalten</button>
    </div>
  </div>

  <!-- ══════════════ SCREEN: PLAYERS ══════════════ -->
