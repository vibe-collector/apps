    {main:"Dschungel",impostor:"Liane"},
    {main:"Vulkan",impostor:"Lava"}
  ]}
];

const BUILTIN_PAIRS = PAIR_GROUPS.flatMap(g => g.pairs);

// ─── STATE ────────────────────────────────────────────────────────────────────
let customPairs = loadCustomPairs();
let activeGroups = loadActiveGroups(); // set of group labels that are enabled
let selectedPairIndex = -1;   // -1 = random
let players = [];
let gameOrder = [];
let currentRevealIndex = 0;
let impostorIndex = -1;
let currentPair = null;
let wordRevealed = false;
let wmFilter = 'all';

const avatarColors = ['#e8ff00','#ff3c6e','#00e5a0','#7b61ff','#ff9f0a','#00cfff','#ff6b35','#c77dff'];

// ─── PERSISTENCE ──────────────────────────────────────────────────────────────
function loadCustomPairs() {
  try { return JSON.parse(localStorage.getItem('impostor_custom_pairs') || '[]'); }
  catch { return []; }
}
function loadActiveGroups() {
  try {
    const saved = JSON.parse(localStorage.getItem('impostor_active_groups'));
    if (Array.isArray(saved)) return new Set(saved);
  } catch {}
  // default: all groups active
  return new Set(PAIR_GROUPS.map(g => g.label));
}
function saveActiveGroups() {
  try { localStorage.setItem('impostor_active_groups', JSON.stringify([...activeGroups])); }
  catch {}
}
function saveCustomPairs() {
  try { localStorage.setItem('impostor_custom_pairs', JSON.stringify(customPairs)); }
  catch {}
}
function allPairs() {
  const builtins = PAIR_GROUPS
    .filter(g => activeGroups.has(g.label))
    .flatMap(g => g.pairs)
    .map(p => ({ ...p, source:'builtin' }));
  return [
    ...builtins,
    ...customPairs.map(p => ({ ...p, source:'custom' })),
  ];
}

// ─── NAVIGATION ───────────────────────────────────────────────────────────────
function goto(screenId) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(screenId).classList.add('active');
  if (screenId === 'screen-wordmanager') renderWordManager();
  if (screenId === 'screen-players') renderGroupToggles();
}

// ─── TOAST ────────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ─── COLLAPSIBLE ──────────────────────────────────────────────────────────────
function toggleSection(bodyId, chevronId) {
  const body = document.getElementById(bodyId);
  const chev = document.getElementById(chevronId);
  body.classList.toggle('open');
  chev.classList.toggle('open');
  if (body.classList.contains('open')) renderPairGrid();
}

// ─── PLAYERS ──────────────────────────────────────────────────────────────────
function addPlayer() {
  const input = document.getElementById('player-input');
  const name = input.value.trim();
  if (!name) return;
  if (players.includes(name)) { showToast('Name bereits vorhanden!'); return; }
  if (players.length >= 12) { showToast('Maximal 12 Spieler!'); return; }
  players.push(name);
  input.value = '';
  renderPlayers();
  input.focus();
}
function removePlayer(i) { players.splice(i,1); renderPlayers(); }
function renderPlayers() {
  document.getElementById('player-list').innerHTML = players.map((name,i) => `
    <div class="player-chip">
      <div class="player-avatar" style="background:${avatarColors[i%avatarColors.length]};color:#000">${name[0].toUpperCase()}</div>
      <span class="player-name">${esc(name)}</span>
      <button class="remove-btn" onclick="removePlayer(${i})">×</button>
    </div>`).join('');
}

// ─── GROUP TOGGLES (players screen) ──────────────────────────────────────────
function renderGroupToggles() {
  const list = document.getElementById('group-toggle-list');
  if (!list) return;
  const allOn = PAIR_GROUPS.every(g => activeGroups.has(g.label));
  list.innerHTML =
    `<span class="group-select-all" onclick="toggleAllGroups(${allOn})">${allOn ? 'Alle deaktivieren' : 'Alle aktivieren'}</span>` +
    PAIR_GROUPS.map(g => `
      <div class="group-toggle-row">
        <span class="group-toggle-label">${esc(g.label)}</span>
        <span class="group-count">${g.pairs.length} Paare</span>
        <button class="toggle-switch ${activeGroups.has(g.label)?'on':''}"
          onclick="toggleGroup(${JSON.stringify(g.label).replace(/"/g,'&quot;')})"></button>
      </div>`).join('') +
    (customPairs.length > 0 ? `
      <div class="group-toggle-row">
        <span class="group-toggle-label">⭐ Eigene Paare</span>
        <span class="group-count">${customPairs.length} Paare</span>
        <button class="toggle-switch on" style="opacity:0.5;cursor:default"></button>
      </div>` : '');
  updateActiveGroupCount();
}

function toggleGroup(label) {
  if (activeGroups.has(label)) {
    if (activeGroups.size <= 1 && customPairs.length === 0) {
      showToast('Mindestens eine Kategorie muss aktiv sein!'); return;
    }
    activeGroups.delete(label);
  } else {
    activeGroups.add(label);
  }
  saveActiveGroups();
  renderGroupToggles();
}

function toggleAllGroups(currentlyAllOn) {
  if (currentlyAllOn) {
    // turn all off except first
    activeGroups = new Set([PAIR_GROUPS[0].label]);
  } else {
    activeGroups = new Set(PAIR_GROUPS.map(g => g.label));
  }
  saveActiveGroups();
  renderGroupToggles();
}

function updateActiveGroupCount() {
  const el = document.getElementById('active-group-count');
  if (!el) return;
  const active = PAIR_GROUPS.filter(g => activeGroups.has(g.label)).length;
  const total = PAIR_GROUPS.length;
  el.textContent = active === total ? 'Alle' : `${active} / ${total} aktiv`;
}

// ─── GAME START ───────────────────────────────────────────────────────────────
function startGame() {
  if (players.length < 3) { showToast('Mindestens 3 Spieler nötig!'); return; }
  const pairs = allPairs();
  if (!pairs.length) { showToast('Keine Wortpaare vorhanden!'); return; }
  currentPair = pairs[Math.floor(Math.random()*pairs.length)];
  gameOrder = [...players].sort(()=>Math.random()-0.5);
  impostorIndex = Math.floor(Math.random()*gameOrder.length);
  currentRevealIndex = 0;
  goto('screen-reveal');
  renderRevealScreen();
}

// ─── REVEAL ───────────────────────────────────────────────────────────────────
function renderRevealScreen() {
  wordRevealed = false;
  const card = document.getElementById('reveal-card');
  card.classList.remove('impostor-card','safe-card');
  const isImpostor = currentRevealIndex===impostorIndex;
  const total = gameOrder.length;
  document.getElementById('reveal-counter').textContent = `Spieler ${currentRevealIndex+1} von ${total}`;
  document.getElementById('progress-fill').style.width = `${(currentRevealIndex/total)*100}%`;
  document.getElementById('reveal-name').textContent = gameOrder[currentRevealIndex];
  const badge = document.getElementById('reveal-badge');
  badge.className = 'role-badge '+(isImpostor?'badge-impostor':'badge-safe');
  badge.textContent = isImpostor?'🎭 Impostor!':'✅ Mitspieler';
  document.getElementById('reveal-word-btn').style.display='block';
  document.getElementById('reveal-word-btn').textContent='👆 Tippen um aufzudecken';
  document.getElementById('reveal-word-display').style.display='none';
  document.getElementById('next-btn').style.display='none';
  document.getElementById('reveal-badge').style.display='none';
  document.getElementById('reveal-hint').textContent = isImpostor
    ? 'Du bist der Impostor! Dein Tarnwort hilft dir in der ersten Runde.'
    : 'Merke dir das Wort. Verrate es nicht! Gib das Gerät weiter wenn du fertig bist.';
  document.getElementById('reveal-dots').innerHTML = gameOrder.map((_,i)=>
    `<div class="dot ${i<currentRevealIndex?'done':i===currentRevealIndex?'current':''}"></div>`
  ).join('');
}
function revealWord() {
  if (wordRevealed) return;
  wordRevealed = true;
  const isImpostor = currentRevealIndex===impostorIndex;
  document.getElementById('reveal-card').classList.add(isImpostor?'impostor-card':'safe-card');
  document.getElementById('reveal-badge').style.display='';
  document.getElementById('reveal-word-btn').style.display='none';
  document.getElementById('reveal-word-display').style.display='block';
  const wt = document.getElementById('word-text');
  wt.textContent = isImpostor ? currentPair.impostor : currentPair.main;
  wt.className = 'word-display '+(isImpostor?'impostor-word':'safe-word');
  document.getElementById('next-btn').style.display='block';
}
function nextPlayer() {
  currentRevealIndex++;
  if (currentRevealIndex>=gameOrder.length) {
    document.getElementById('play-word-count').textContent =
      `${gameOrder.length} Spieler`;
    goto('screen-play');
    return;
  }
  renderRevealScreen();
}
function newRound() { startGame(); }

// ─── WORD MANAGER ─────────────────────────────────────────────────────────────
function renderWordManager() {
  renderWmStats();
  renderAllPairsList();
}
function renderWmStats() {
  const c = customPairs.length, t = BUILTIN_PAIRS.length+c;
  document.getElementById('wm-stats').innerHTML = `
    <div class="stat-chip"><strong>${t}</strong><span>Gesamt</span></div>
    <div class="stat-chip"><strong style="color:var(--accent)">${c}</strong><span>Eigene</span></div>
    <div class="stat-chip"><strong style="color:var(--muted)">${BUILTIN_PAIRS.length}</strong><span>Standard</span></div>`;
}
function switchWmTab(tab) {
  ['list','add','import'].forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('active', t===tab);
    document.getElementById('panel-'+t).classList.toggle('active', t===tab);
  });
  if (tab==='list') renderAllPairsList();
}
function setFilter(f) {
  wmFilter = f;
  ['all','custom','builtin'].forEach(x =>
    document.getElementById('filter-'+x).classList.toggle('active', x===f));
  renderAllPairsList();
}
function renderAllPairsList() {
  const pairs = allPairs();
  const filtered = wmFilter==='all' ? pairs : pairs.filter(p=>p.source===wmFilter);
  const list = document.getElementById('all-pairs-list');
  if (!filtered.length) {
    list.innerHTML = `<div style="color:var(--muted);text-align:center;padding:30px;font-size:14px">Keine Paare vorhanden</div>`;
  } else {
    list.innerHTML = filtered.map((p, fi) => {
      // find global index in allPairs()
      const globalIdx = pairs.indexOf(p);
      return `
      <div class="custom-pair-item">
        <div class="custom-pair-words">
          <span class="cw-main">${esc(p.main)}</span>
          <span class="cw-sep">›</span>
          <span class="cw-impostor">${esc(p.impostor)}</span>
        </div>
        <span class="cw-source ${p.source}">${p.source==='custom'?'Eigenes':'Standard'}</span>
        <button class="edit-btn" onclick="openEditModal(${globalIdx})" title="Bearbeiten">✏️</button>
        ${p.source==='custom' ? `<button class="remove-btn" onclick="deletePairByGlobal(${globalIdx})" title="Löschen">×</button>` : ''}
      </div>`;
    }).join('');
  }
  document.getElementById('delete-all-custom-btn').style.display = customPairs.length>0?'block':'none';
  renderWmStats();
}

// ─── EDIT MODAL ───────────────────────────────────────────────────────────────
// editingGlobalIdx: index into allPairs() — builtin first, then custom
let editingGlobalIdx = -1;

function openEditModal(globalIdx) {
  editingGlobalIdx = globalIdx;
  const p = allPairs()[globalIdx];
  document.getElementById('edit-main').value = p.main;
  document.getElementById('edit-impostor').value = p.impostor;
  document.getElementById('edit-modal').classList.add('open');
  setTimeout(() => document.getElementById('edit-main').focus(), 350);
}

function closeEditModal(e) {
  if (e && e.target !== document.getElementById('edit-modal')) return;
  document.getElementById('edit-modal').classList.remove('open');
  editingGlobalIdx = -1;
}

function saveEdit() {
  if (editingGlobalIdx < 0) return;
  const main = document.getElementById('edit-main').value.trim();
  const imp  = document.getElementById('edit-impostor').value.trim();
  if (!main || !imp) { showToast('Bitte beide Felder ausfüllen!'); return; }

  const pairs = allPairs();
  const oldMain = pairs[editingGlobalIdx].main;

  // Duplicate check (ignore same pair)
  if (main.toLowerCase() !== oldMain.toLowerCase() &&
      pairs.some(p => p.main.toLowerCase() === main.toLowerCase())) {
    showToast(`"${main}" ist bereits vorhanden!`); return;
  }

  if (editingGlobalIdx < BUILTIN_PAIRS.length) {
    // Edit builtin directly
    BUILTIN_PAIRS[editingGlobalIdx] = { main, impostor: imp };
  } else {
    // Edit custom
    const customIdx = editingGlobalIdx - BUILTIN_PAIRS.length;
    customPairs[customIdx] = { main, impostor: imp };
    saveCustomPairs();
  }

  // Update selected pair display if this was selected
  if (selectedPairIndex === editingGlobalIdx) {
    document.getElementById('selected-pair-display').textContent = main + ' / ' + imp;
  }

  document.getElementById('edit-modal').classList.remove('open');
  editingGlobalIdx = -1;
  renderAllPairsList();
  showToast(`✅ "${main} / ${imp}" gespeichert`);
}

// ─── ADD SINGLE PAIR ──────────────────────────────────────────────────────────
function addSinglePair() {
  const main = document.getElementById('add-main').value.trim();
  const imp  = document.getElementById('add-impostor').value.trim();
  if (!main||!imp) { showToast('Bitte beide Felder ausfüllen!'); return; }
  const all = allPairs();
  if (all.some(p=>p.main.toLowerCase()===main.toLowerCase())) {
    showToast(`"${main}" ist schon vorhanden!`); return;
  }
  customPairs.push({ main, impostor:imp });
  saveCustomPairs();
  document.getElementById('add-main').value='';
  document.getElementById('add-impostor').value='';
  document.getElementById('add-main').focus();
  renderWmStats();
  showToast(`✅ "${main} / ${imp}" hinzugefügt!`);
}

// ─── DELETE ───────────────────────────────────────────────────────────────────
function deletePairByGlobal(globalIdx) {
  const customIdx = globalIdx - BUILTIN_PAIRS.length;
  deletePair(customIdx);
}
function deletePair(idx) {
  if (idx<0||idx>=customPairs.length) return;
  const name = customPairs[idx].main;
  customPairs.splice(idx,1);
  saveCustomPairs();
  if (selectedPairIndex >= BUILTIN_PAIRS.length) selectedPairIndex=-1;
  renderAllPairsList();
  showToast(`"${name}" gelöscht`);
}
function deleteAllCustom() {
  if (!confirm(`Alle ${customPairs.length} eigenen Wortpaare löschen?`)) return;
  customPairs=[];
  saveCustomPairs();
  selectedPairIndex=-1;
  renderAllPairsList();
  showToast('Alle eigenen Paare gelöscht');
}

// ─── IMPORT TEXT ──────────────────────────────────────────────────────────────
function importFromText() {
  const raw = document.getElementById('import-textarea').value.trim();
  if (!raw) { showToast('Kein Text eingegeben!'); return; }
  const r = parsePairsText(raw);
  if (!r.added) { showToast('Keine neuen Paare gefunden. Format: Hauptwort ; Tarnwort'); return; }
  document.getElementById('import-textarea').value='';
  renderWmStats();
  switchWmTab('list');
  showToast(`✅ ${r.added} Paare importiert${r.skipped?`, ${r.skipped} übersprungen`:''}`);
}
function parsePairsText(raw) {
  const lines = raw.split('\n').map(l=>l.trim()).filter(Boolean);
  let added=0, skipped=0;
  const all = allPairs();
  for (const line of lines) {
    if (line.startsWith('#')) continue; // skip header/comment lines
    const sep = line.includes(';') ? ';' : ',';
    const parts = line.split(sep).map(s=>s.trim());
    if (parts.length<2||!parts[0]||!parts[1]) { skipped++; continue; }
    const [main,imp] = parts;
    if (all.some(p=>p.main.toLowerCase()===main.toLowerCase())) { skipped++; continue; }
    customPairs.push({ main, impostor:imp });
    all.push({ main, impostor:imp, source:'custom' });
    added++;
  }
  if (added) saveCustomPairs();
  return { added, skipped };
}

// ─── FILE IMPORT ──────────────────────────────────────────────────────────────
function handleFileImport(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const r = parsePairsText(ev.target.result);
    e.target.value='';
    if (!r.added) { showToast('Keine neuen Paare gefunden.'); return; }
    renderWmStats();
    switchWmTab('list');
    showToast(`✅ ${r.added} Paare aus Datei importiert${r.skipped?`, ${r.skipped} übersprungen`:''}`);
  };
  reader.readAsText(file,'UTF-8');
}

// Drag & Drop
document.addEventListener('DOMContentLoaded', () => {
  const dz = document.getElementById('drop-zone');
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('dragover'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('dragover'));
  dz.addEventListener('drop', e => {
    e.preventDefault(); dz.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      const r = parsePairsText(ev.target.result);
      if (!r.added) { showToast('Keine neuen Paare gefunden.'); return; }
      renderWmStats();
      switchWmTab('list');
      showToast(`✅ ${r.added} Paare importiert${r.skipped?`, ${r.skipped} übersprungen`:''}`);
    };
    reader.readAsText(file,'UTF-8');
  });
});

// ─── EXPORT ───────────────────────────────────────────────────────────────────
function exportCustomPairs() {
  if (!customPairs.length) { showToast('Keine eigenen Paare zum Exportieren!'); return; }
  const csv = 'Hauptwort;Tarnwort\n' + customPairs.map(p=>`${p.main};${p.impostor}`).join('\n');
  const a = Object.assign(document.createElement('a'), {
    href: URL.createObjectURL(new Blob([csv],{type:'text/csv;charset=utf-8;'})),
    download: 'impostor-wortpaare.csv'
  });
  a.click();
  showToast(`✅ ${customPairs.length} Paare exportiert`);
}


// ─── PIN PROTECTION ───────────────────────────────────────────────────────────
const MANAGER_PIN = '1701';

function showPinPrompt() {
  document.getElementById('pin-input').value = '';
  document.getElementById('pin-error').textContent = '';
  document.getElementById('pin-modal').classList.add('open');
  setTimeout(() => document.getElementById('pin-input').focus(), 350);
}

function closePinModal(e) {
  if (e && e.target !== document.getElementById('pin-modal')) return;
  document.getElementById('pin-modal').classList.remove('open');
}

function clearPinError() {
  document.getElementById('pin-error').textContent = '';
}

function checkPin() {
  const val = document.getElementById('pin-input').value.trim();
  if (val === MANAGER_PIN) {
    document.getElementById('pin-modal').classList.remove('open');
    goto('screen-wordmanager');
  } else {
    document.getElementById('pin-error').textContent = '❌ Falscher Code. Bitte erneut versuchen.';
    document.getElementById('pin-input').value = '';
    document.getElementById('pin-input').focus();
  }
}

// ─── HELPERS ──────────────────────────────────────────────────────────────────
function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
